# =====================================================================
# Variables de entorno de ejemplo.
# Copia este archivo como `.env` y rellena tus propias credenciales.
# El archivo `.env` está ignorado por git y NUNCA debe subirse al repo.
# =====================================================================

# --- Supabase ---
# URL del proyecto (Settings > API > Project URL)
SUPABASE_URL=https://tu-proyecto.supabase.co
# Clave pública anónima (Settings > API > Project API keys > anon public)
SUPABASE_ANON_KEY=tu_supabase_anon_key

# --- Google Gemini ---
# Crea tu API key en: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=tu_google_genai_api_key
